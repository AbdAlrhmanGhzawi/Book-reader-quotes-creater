<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginTop="5dp"
    android:layout_marginEnd="10dp"
    android:layout_marginBottom="5dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="10dp"
    app:contentPadding="10dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <com.makeramen.roundedimageview.RoundedImageView
            android:id="@+id/imgQuotationImage"
            android:layout_width="80dp"
            android:layout_height="100dp"
            android:layout_alignParentStart="true"
            android:layout_marginEnd="10dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_book"
            app:riv_corner_radius="10dp"
            app:riv_mutate_background="true"
            app:riv_oval="false" />

        <TextView
            android:id="@+id/txtQuotationName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/imgQuotationImage"
            android:ellipsize="end"
            android:gravity="start"
            android:maxLines="1"
            android:textColor="#000"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:text="Author Name" />

        <TextView
            android:id="@+id/txtQuotationPage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/txtQuotationName"
            android:layout_toEndOf="@+id/imgQuotationImage"
            android:ellipsize="end"
            android:gravity="start"
            android:maxLines="1"
            android:textColor="#710A0A"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="500" />

        <TextView
            android:id="@+id/txtQuotationContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/txtQuotationPage"
            android:layout_toEndOf="@+id/imgQuotationImage"
            android:ellipsize="end"
            android:gravity="start"
            android:maxLines="3"
            android:textColor="#000000"
            android:textSize="22sp"
            tools:text="َQuoteَQuoteَQuoteَQuoteَQuoteَQuoteَQuoteَQuoteَQuoteَQuoteَQuoteَQuoteَQuoteَQuoteَQuote" />

    </RelativeLayout>


</androidx.cardview.widget.CardView>